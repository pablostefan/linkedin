PORT=3901
APP_BASE_URL=http://localhost:3901
SESSION_SECRET=change-me

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3901/auth/linkedin/callback

# Ajuste para uma versao suportada pela sua app no LinkedIn.
LINKEDIN_API_VERSION=202504

# Escopos basicos para login + postagem no perfil pessoal.
# Para listar posts ja publicados no perfil pessoal, o app tambem precisa do escopo
# restrito r_member_social aprovado no LinkedIn. Quando isso estiver liberado, use:
# LINKEDIN_SCOPES=openid profile email w_member_social r_member_social
LINKEDIN_SCOPES=openid profile email w_member_social